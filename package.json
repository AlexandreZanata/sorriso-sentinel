{
  "name": "sorriso-sentinel",
  "version": "0.1.0",
  "private": true,
  "description": "Open source monitoring and sentinel platform",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.19.4"
  },
  "packageManager": "pnpm@10.14.0",
  "pnpm": {
    "overrides": {
      "react": "19.2.7",
      "react-dom": "19.2.7"
    },
    "onlyBuiltDependencies": [
      "sharp"
    ]
  },
  "scripts": {
    "prepare": "husky",
    "setup": "bash scripts/setup.sh",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "pnpm run lint:root && turbo run lint",
    "lint:root": "markdownlint-cli2",
    "lint:fix": "markdownlint-cli2 --fix",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "validate:oss": "bash scripts/validate-oss.sh",
    "validate:version": "bash scripts/validate-version.sh",
    "validate:branch": "bash scripts/check-branch.sh",
    "validate": "pnpm run validate:oss && pnpm run validate:version && pnpm run lint:root && turbo run lint test typecheck build",
    "validate:security": "bash scripts/security-audit.sh",
    "check": "pnpm run validate:branch && pnpm run validate && pnpm run validate:security && pnpm run docker:validate && pnpm run docker:prod-validate",
    "commitlint": "commitlint --edit",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d --wait",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:validate": "bash scripts/docker-validate.sh",
    "docker:prod-validate": "bash scripts/docker-prod-validate.sh",
    "docker:api-smoke": "bash scripts/docker-api-smoke.sh",
    "docker:api-routes": "bash scripts/docker-api-routes.sh",
    "db:migrate": "bash scripts/migrate.sh"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "husky": "^9.1.7",
    "markdownlint-cli2": "^0.22.1",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  }
}
