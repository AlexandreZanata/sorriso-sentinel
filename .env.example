# Application environment — copy to .env and adjust values.
# Never commit .env to version control.

# Runtime
NODE_ENV=development
LOG_LEVEL=debug

# Server (when application stack is defined)
# PORT=3000
# HOST=0.0.0.0

# Database (when application stack is defined)
# DATABASE_URL=postgresql://sentinel:sentinel@localhost:5432/sorriso_sentinel

# Cache (when application stack is defined)
# REDIS_URL=redis://localhost:6379

# Observability
# CORRELATION_ID_HEADER=x-correlation-id

# Multitenancy (when applicable)
# TENANT_HEADER=x-tenant-id
