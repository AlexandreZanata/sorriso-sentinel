# Application environment — copy to .env and adjust values.
# Never commit .env to version control.

NODE_ENV=development
LOG_LEVEL=debug

# API (NestJS)
PORT=3000

# Web (Next.js)
WEB_PORT=3001

# Mobile (Expo)
EXPO_PUBLIC_API_URL=http://127.0.0.1:3010
EXPO_PUBLIC_DEFAULT_CITY_ID=01932f1a-0000-7000-8000-000000000001

# Database — PostgreSQL 18.1 + PostGIS
# API runtime: sentinel_app (RLS enforced). Use sentinel superuser for migrations only.
DATABASE_URL=postgresql://sentinel_app:sentinel_app@localhost:5432/sorriso_sentinel

# Redis + BullMQ
REDIS_URL=redis://localhost:6379

# S3-compatible storage (MinIO local)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=sentinel
S3_SECRET_KEY=sentinelsecret
S3_BUCKET=sorriso-sentinel-media
S3_REGION=us-east-1

# Media upload limits (Phase 5)
MAX_IMAGES_PER_OCCURRENCE=5
MAX_MEDIA_FILE_SIZE_MB=10
MAX_UPLOAD_SLOTS_PER_HOUR=20
PRESIGNED_URL_TTL_SECONDS=900
MEDIA_PROCESS_INLINE=true

# Community validation rate limits (Phase 4)
MAX_VALIDATION_VOTES_PER_HOUR=30
VALIDATION_RATE_LIMIT_WINDOW_SECONDS=3600

# JWT access + refresh tokens (Phase 6)
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800
JWT_ISSUER=sorriso-sentinel
JWT_AUDIENCE=sorriso-sentinel-api
JWT_ACCESS_SECRET=dev-jwt-secret-change-me
BCRYPT_COST=12

# Production HTTP security (Phase 8) — required when NODE_ENV=production
# Comma-separated allowlist; never use * with credentials
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
TRUST_PROXY=false

# Observability
CORRELATION_ID_HEADER=x-correlation-id

# Multitenancy
TENANT_HEADER=x-city-id
