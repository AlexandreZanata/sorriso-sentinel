# Application environment — copy to .env and adjust values.
# Never commit .env to version control.

NODE_ENV=development
LOG_LEVEL=debug

# API (NestJS)
PORT=3000

# Web (Next.js)
WEB_PORT=3001

# Database — PostgreSQL 18.1 + PostGIS
DATABASE_URL=postgresql://sentinel:sentinel@localhost:5432/sorriso_sentinel

# Redis + BullMQ
REDIS_URL=redis://localhost:6379

# S3-compatible storage (MinIO local)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=sentinel
S3_SECRET_KEY=sentinelsecret
S3_BUCKET=sorriso-sentinel-media
S3_REGION=us-east-1

# Media upload limits (Phase 5)
MAX_IMAGES_PER_OCCURRENCE=5
MAX_MEDIA_FILE_SIZE_MB=10
MAX_UPLOAD_SLOTS_PER_HOUR=20
PRESIGNED_URL_TTL_SECONDS=900
MEDIA_PROCESS_INLINE=true

# Observability
CORRELATION_ID_HEADER=x-correlation-id

# Multitenancy
TENANT_HEADER=x-city-id
