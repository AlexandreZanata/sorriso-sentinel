{
  "expo": {
    "name": "Sorriso Sentinel",
    "slug": "sorriso-sentinel",
    "version": "0.1.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "scheme": "sorriso-sentinel",
    "platforms": [
      "ios",
      "android"
    ],
    "android": {
      "usesCleartextTraffic": true,
      "package": "com.anonymous.sorrisosentinel"
    },
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      "expo-dev-client",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.1.20"
          }
        }
      ],
      "expo-localization",
      "expo-secure-store"
    ]
  }
}
