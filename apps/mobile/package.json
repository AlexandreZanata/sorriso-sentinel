{
  "name": "@sorriso-sentinel/mobile",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "main": "index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "dev:client": "expo start --dev-client --port 8082",
    "android:configure": "bash scripts/write-android-local-properties.sh",
    "android": "bash scripts/write-android-local-properties.sh && expo run:android --port 8082",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild",
    "dev": "expo start",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.18.2",
    "@react-navigation/native": "^7.3.3",
    "@react-navigation/native-stack": "^7.17.5",
    "@sorriso-sentinel/mwm-engine": "workspace:*",
    "@sorriso-sentinel/shared": "workspace:*",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^14.0.0",
    "expo": "~56.0.12",
    "expo-build-properties": "0.13.3",
    "expo-dev-client": "~6.0.16",
    "expo-crypto": "^15.0.9",
    "expo-file-system": "~19.0.17",
    "expo-localization": "^17.0.9",
    "expo-secure-store": "^15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-webview": "~13.15.0",
    "react-test-renderer": "19.1.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
